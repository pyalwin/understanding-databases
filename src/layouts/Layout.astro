---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Databases Deep-Dive' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Advanced databases learning course" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100 antialiased">
    <header class="border-b border-white/10">
      <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between">
        <a class="text-sm font-semibold tracking-wide text-white" href="/">
          {title}
        </a>
        <nav class="text-sm text-gray-300">
          <a class="hover:text-white" href="/chapters">Chapters</a>
          <span class="mx-2 text-gray-700">|</span>
          <a class="hover:text-white" href="/sandbox">Sandbox</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-white/10">
      <div class="mx-auto max-w-6xl px-4 py-6 text-xs text-gray-500">
        Built with Astro + Cloudflare Workers + SQLite in the browser
      </div>
    </footer>
  </body>
</html>
