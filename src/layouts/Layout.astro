---
import '../styles/global.css';
import BrandLogo from '@/components/BrandLogo.astro';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  headerLabel?: string;
  hideHeader?: boolean;
}

const SITE_NAME = 'Databases: Under the Hood';
const DEFAULT_DESC =
  'Databases, the first Under the Hood book: an interactive deep-dive into how databases actually work. Read in the page, run the experiments, break things on purpose.';

const {
  title,
  description = DEFAULT_DESC,
  type = 'website',
  headerLabel,
  hideHeader = false,
} = Astro.props;

// Full <title>: chapter pages get a "— Databases: Under the Hood" suffix;
// the home page (title === SITE_NAME or unset) stands alone.
const pageTitle = title && title !== SITE_NAME ? `${title} — ${SITE_NAME}` : SITE_NAME;

// Astro.site comes from `site` in astro.config.mjs; canonical strips any trailing slash.
const canonical = new URL(Astro.url.pathname, Astro.site).href.replace(/\/$/, '');
const ogImage = new URL('/og-image.svg', Astro.site).href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter+Tight:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen">
    {!hideHeader && (
      <header class="sticky top-0 z-30 border-b border-[color:var(--color-rule)] bg-[color:var(--color-page)]/95 backdrop-blur relative">
        <div class="page-column px-6 py-3.5 flex items-center justify-between gap-4 min-w-0">
          <div class="flex items-center gap-3 min-w-0">
            {headerLabel && (
              <button
                type="button"
                data-global-toc-toggle
                class="lg:hidden flex-shrink-0 -ml-1 p-1.5 rounded-md text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] hover:bg-[color:var(--color-rule)]/50 transition-colors"
                aria-label="Open table of contents"
              >
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                  <line x1="3" y1="5" x2="15" y2="5" />
                  <line x1="3" y1="9" x2="15" y2="9" />
                  <line x1="3" y1="13" x2="15" y2="13" />
                </svg>
              </button>
            )}
            <BrandLogo />
          </div>
          <div class="flex items-center justify-end gap-3 min-w-0 flex-1">
            {headerLabel && (
              <div
                class="font-sans text-[12px] sm:text-[13px] text-[color:var(--color-ink-soft)] truncate text-right min-w-0"
                title={headerLabel}
              >
                {headerLabel}
              </div>
            )}
          </div>
        </div>
        {headerLabel && (
          <div class="absolute inset-x-0 -bottom-px h-px bg-transparent" aria-hidden="true">
            <div
              class="h-full bg-[color:var(--color-ink)] transition-all duration-500"
              style="width: 0%;"
              data-progress-bar
            ></div>
          </div>
        )}
      </header>
    )}
    <main>
      <slot />
    </main>
  </body>
</html>
