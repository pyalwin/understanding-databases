---
import '../styles/global.css';

interface Props { title?: string; }
const { title = 'Understanding Databases' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A deep, narrative course on database internals." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=Inter+Tight:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[color:var(--color-rule)] bg-[color:var(--color-page)]">
      <div class="page-column px-6 py-4 flex items-center justify-between">
        <a class="font-sans text-sm font-semibold tracking-wide" href="/">
          Understanding Databases
        </a>
        <nav class="font-sans text-sm text-[color:var(--color-ink-soft)] flex gap-5">
          <a class="hover:text-[color:var(--color-accent)]" href="/chapters">Chapters</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
