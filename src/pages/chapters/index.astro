---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const chapters = (await getCollection('chapters'))
  .filter((c) => c.id !== '_test')
  .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
---

<Layout
  title="Chapters"
  description="The full table of contents for Databases: Under the Hood, from why databases are special through transactions, isolation, storage, query execution, MVCC, and crash recovery with ARIES."
>
  <section class="prose-column px-6 pt-12 pb-24">
    <p class="font-sans text-xs tracking-[0.18em] uppercase text-[color:var(--color-accent)] mb-2">
      Contents
    </p>
    <h1 class="text-4xl font-semibold mb-10">Chapters</h1>
    <ol class="space-y-3 list-none p-0">
      {chapters.map((c) => {
        const num = String(c.data.chapterNumber).padStart(2, '0');
        return (
          <li class="border-b border-[color:var(--color-rule)] py-2">
            <a class="group flex items-baseline gap-4 hover:text-[color:var(--color-accent)]" href={`/chapters/${c.id}`}>
              <span class="font-mono text-xs text-[color:var(--color-ink-soft)] w-8 group-hover:text-[color:var(--color-accent)]">{num}</span>
              <span class="flex-1">{c.data.title}</span>
              <span class="text-[color:var(--color-ink-soft)] transition-transform group-hover:translate-x-1 group-hover:text-[color:var(--color-accent)]" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        );
      })}
    </ol>
  </section>
</Layout>
