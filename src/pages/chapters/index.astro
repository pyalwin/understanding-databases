---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const chapters = (await getCollection('chapters'))
  .filter((c) => c.id !== '_test')
  .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
---

<Layout title="Chapters">
  <section class="prose-column px-6 pt-12 pb-24">
    <p class="font-sans text-xs tracking-[0.18em] uppercase text-[color:var(--color-accent)] mb-2">
      Contents
    </p>
    <h1 class="text-4xl font-semibold mb-10">Chapters</h1>
    <ol class="space-y-3 list-none p-0">
      {chapters.map((c) => {
        const num = String(c.data.chapterNumber).padStart(2, '0');
        const isDraft = c.data.status === 'draft';
        return (
          <li class="flex items-baseline gap-4 border-b border-[color:var(--color-rule)] py-2">
            <span class="font-mono text-xs text-[color:var(--color-ink-soft)] w-8">{num}</span>
            {isDraft ? (
              <span class="flex-1 text-[color:var(--color-ink-soft)]">
                {c.data.title} <span class="ml-2 text-xs uppercase tracking-wider">draft</span>
              </span>
            ) : (
              <a class="flex-1 hover:text-[color:var(--color-accent)]" href={`/chapters/${c.id}`}>
                {c.data.title}
              </a>
            )}
          </li>
        );
      })}
    </ol>
  </section>
</Layout>
