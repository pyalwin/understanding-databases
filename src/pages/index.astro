---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Databases Deep-Dive">
  <section class="space-y-6">
    <h1 class="text-3xl font-bold tracking-tight">Databases Deep-Dive</h1>
    <p class="text-gray-300 text-lg">
      An engineering-first course on how databases actually work: storage engines,
      indexing, concurrency, recovery, replication, and modern system internals.
    </p>
    <div class="grid gap-4 sm:grid-cols-2">
      <a href="/chapters" class="block rounded-lg border border-white/10 p-4 hover:bg-white/5">
        <div class="font-medium">Chapters</div>
        <div class="text-sm text-gray-400">Read and interact with course content</div>
      </a>
      <a href="/sandbox" class="block rounded-lg border border-white/10 p-4 hover:bg-white/5">
        <div class="font-medium">SQL Sandbox</div>
        <div class="text-sm text-gray-400">Run SQLite queries in the browser</div>
      </a>
    </div>
    <div id="progress" class="text-sm text-gray-400">Loading progress…</div>
  </section>

  <script is:inline>
    const updateProgress = () => {
      const data = JSON.parse(localStorage.getItem('course-progress') || '{}');
      const total = 19;
      const done = Object.values(data).filter(Boolean).length;
      const pct = Math.round((done / total) * 100);
      document.getElementById('progress').textContent = `Progress: ${done}/${total} chapters (${pct}%)`;
    };
    updateProgress();
  </script>
</Layout>
